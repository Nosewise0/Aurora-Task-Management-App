<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="mb-4">
            <h1 class="fw-bold mb-1">Invite Team Member</h1>
            <p class="text-secondary">Send an invitation to join your workspace.</p>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="glass-card p-4">
                    <form action="/team/invite" method="POST">
                        <!-- Member Email -->
                        <div class="mb-4">
                            <label for="email" class="form-label fw-semibold" style="color: var(--text-main);">Email
                                Address</label>
                            <input type="email" class="form-control bg-main border-color p-3" id="email"
                                name="invite[email]" placeholder="colleague@example.com" required
                                style="background: var(--bg-main) !important; color: var(--text-main);">
                        </div>

                        <div class="row">
                            <!-- Role Selection -->
                            <div class="col-md-6 mb-4">
                                <label for="role" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Role</label>
                                <select class="form-select bg-main border-color p-3" id="role" name="invite[role]"
                                    style="background: var(--bg-main) !important; color: var(--text-main);">
                                    <option value="Member">Member</option>
                                    <option value="Developer">Developer</option>
                                    <option value="Designer">Designer</option>
                                    <option value="Manager">Manager</option>
                                    <option value="Admin">Admin</option>
                                </select>
                            </div>

                            <!-- Workspace/Project -->
                            <div class="col-md-6 mb-4">
                                <label for="workspace" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Initial Workspace</label>
                                <select class="form-select bg-main border-color p-3" id="workspace"
                                    name="invite[workspace]"
                                    style="background: var(--bg-main) !important; color: var(--text-main);">
                                    <option value="All">All Projects</option>
                                    <option value="Aurora">Aurora Task Management</option>
                                    <option value="Internal">Internal Tools</option>
                                </select>
                            </div>
                        </div>

                        <!-- Personal Note -->
                        <div class="mb-4">
                            <label for="note" class="form-label fw-semibold" style="color: var(--text-main);">Personal
                                Note (Optional)</label>
                            <textarea class="form-control bg-main border-color p-3" id="note" name="invite[note]"
                                rows="3" placeholder="Hey! Join our team on Aurora..."
                                style="background: var(--bg-main) !important; color: var(--text-main);"></textarea>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex gap-3 mt-2">
                            <button type="submit" class="btn-premium px-5 py-3">
                                <i class="fas fa-paper-plane me-2"></i>Send Invitation
                            </button>
                            <a href="/team"
                                class="btn btn-outline-secondary border-color px-4 py-3 d-flex align-items-center"
                                style="color: var(--text-secondary);">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Sidebar Info -->
            <div class="col-lg-4">
                <div class="glass-card p-4">
                    <h6 class="fw-bold mb-3"><i class="fas fa-shield-alt me-2 text-primary"></i>Security & Permissions
                    </h6>
                    <p class="smaller text-secondary mb-3">
                        Invited members will receive an email with a secure link to join your team.
                    </p>
                    <ul class="list-unstyled smaller text-secondary mb-0">
                        <li class="mb-2">
                            <i class="fas fa-info-circle me-2 text-info"></i>
                            Roles can be changed later.
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-info-circle me-2 text-info"></i>
                            Invitations expire after 7 days.
                        </li>
                        <li>
                            <i class="fas fa-info-circle me-2 text-info"></i>
                            Admins have full billing control.
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>