<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold mb-1">Projects</h1>
                <p class="text-secondary">Track high-level progress of all active projects.</p>
            </div>
            <a href="/projects/new"
                class="btn-premium text-decoration-none d-flex align-items-center justify-content-center">
                <i class="fas fa-plus me-2"></i>New Project
            </a>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="p-2 bg-primary bg-opacity-10 rounded text-primary">
                            <i class="fas fa-code fa-lg"></i>
                        </div>
                        <div class="badge bg-success bg-opacity-10 text-success">Active</div>
                    </div>
                    <h5 class="fw-bold mb-2">Aurora App Redesign</h5>
                    <p class="text-secondary small mb-4">Redesigning the entire task management interface for a premium
                        look.</p>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Progress</span>
                            <span class="text-primary fw-bold">75%</span>
                        </div>
                        <div class="progress" style="height: 6px; background: var(--bg-main);">
                            <div class="progress-bar" role="progressbar"
                                style="width: 75%; background: var(--accent-primary);" aria-valuenow="75"
                                aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div
                        class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-secondary border-opacity-10">
                        <div class="d-flex">
                            <div class="rounded-circle bg-secondary border border-2 border-dark"
                                style="width: 32px; height: 32px; margin-left: 0; display: flex; align-items: center; justify-content: center; font-size: 10px;">
                                JD</div>
                            <div class="rounded-circle bg-info border border-2 border-dark"
                                style="width: 32px; height: 32px; margin-left: -10px; display: flex; align-items: center; justify-content: center; font-size: 10px;">
                                AS</div>
                        </div>
                        <div class="text-muted small"><i class="far fa-clock me-1"></i>2 days left</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="p-2 bg-warning bg-opacity-10 rounded text-warning">
                            <i class="fas fa-mobile-alt fa-lg"></i>
                        </div>
                        <div class="badge bg-info bg-opacity-10 text-info">Internal</div>
                    </div>
                    <h5 class="fw-bold mb-2">Mobile Companion App</h5>
                    <p class="text-secondary small mb-4">Developing a lightweight React Native app for on-the-go task
                        tracking.</p>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Progress</span>
                            <span class="text-primary fw-bold">30%</span>
                        </div>
                        <div class="progress" style="height: 6px; background: var(--bg-main);">
                            <div class="progress-bar" role="progressbar"
                                style="width: 30%; background: var(--accent-primary);" aria-valuenow="30"
                                aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div
                        class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-secondary border-opacity-10">
                        <div class="d-flex">
                            <div class="rounded-circle bg-primary border border-2 border-dark"
                                style="width: 32px; height: 32px; margin-left: 0; display: flex; align-items: center; justify-content: center; font-size: 10px;">
                                BK</div>
                        </div>
                        <div class="text-muted small"><i class="far fa-clock me-1"></i>12 days left</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="p-2 bg-info bg-opacity-10 rounded text-info">
                            <i class="fas fa-layer-group fa-lg"></i>
                        </div>
                        <div class="badge bg-secondary bg-opacity-10 text-secondary">Planning</div>
                    </div>
                    <h5 class="fw-bold mb-2">API Integration v2</h5>
                    <p class="text-secondary small mb-4">Restructuring the backend API for better performance and
                        scalability.</p>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Progress</span>
                            <span class="text-primary fw-bold">10%</span>
                        </div>
                        <div class="progress" style="height: 6px; background: var(--bg-main);">
                            <div class="progress-bar" role="progressbar"
                                style="width: 10%; background: var(--accent-primary);" aria-valuenow="10"
                                aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div
                        class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-secondary border-opacity-10">
                        <div class="d-flex">
                            <div class="rounded-circle bg-danger border border-2 border-dark"
                                style="width: 32px; height: 32px; margin-left: 0; display: flex; align-items: center; justify-content: center; font-size: 10px;">
                                JD</div>
                        </div>
                        <div class="text-muted small"><i class="far fa-clock me-1"></i>1 month left</div>
                    </div>
                </div>
            </div>
        </div>
    </div>