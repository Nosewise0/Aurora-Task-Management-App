<% layout('layout/boilerplate') %>

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Projects</h1>
            <p class="text-secondary">Track high-level progress of all active projects.</p>
        </div>
        <a href="/projects/new"
           class="btn-premium text-decoration-none d-flex align-items-center justify-content-center">
           <i class="fas fa-plus me-2"></i>New Project
        </a>
    </div>
    <% if (projects.length===0) { %>
     <div class="text-center py-5">
            <h5 class="text-secondary">No projects yet</h5>
            <p class="text-muted">Click the "New Project" button to create your first project.</p>
        </div>
    <%} else { %>
    <div class="row g-4">
        <% projects.forEach(project => { %>
        <div class="col-md-4">
            <a href="/projects/<%= project.id %>" class="text-decoration-none">
                <div class="glass-card h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="p-2 
                            <% if(project.status === 'active') { %> bg-success bg-opacity-10 text-success <% } %>
                            <% if(project.status === 'planning') { %> bg-secondary bg-opacity-10 text-secondary <% } %>
                            <% if(project.status === 'on-hold') { %> bg-warning bg-opacity-10 text-warning <% } %>
                            rounded">
                            <i class="fas fa-layer-group fa-lg"></i>
                        </div>
                        <div class="badge 
                            <% if(project.status === 'active') { %> bg-success bg-opacity-10 text-success <% } %>
                            <% if(project.status === 'planning') { %> bg-secondary bg-opacity-10 text-secondary <% } %>
                            <% if(project.status === 'on-hold') { %> bg-warning bg-opacity-10 text-warning <% } %>">
                            <%= project.status.charAt(0).toUpperCase() + project.status.slice(1) %>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-2 text-dark"><%= project.title %></h5>
                    <p class="text-secondary small mb-4"><%= project.description %></p>

                    <% let progress = 0; 
                       if(project.start_date && project.end_date) { 
                           const now = new Date(); 
                           const start = new Date(project.start_date); 
                           const end = new Date(project.end_date); 
                           progress = Math.min(Math.round(((now - start) / (end - start)) * 100), 100); 
                           progress = progress < 0 ? 0 : progress; 
                       } 
                    %>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-secondary">Progress</span>
                            <span class="text-primary fw-bold"><%= progress %>%</span>
                        </div>
                        <div class="progress" style="--progress: <%= progress %>%;">
                            <div class="progress-bar" role="progressbar" aria-valuenow="<%= progress %>"
                                aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-secondary border-opacity-10">
                        <div class="text-muted small">
                            <%= (() => { 
                                let now = new Date(); 
                                let endDate = new Date(project.end_date); 
                                let diffDays = Math.ceil((endDate - now) / (1000 * 60 * 60 * 24)); 
                                return diffDays > 0 ? diffDays + ' days left' : 'Ended'; 
                            })() %>
                        </div>
                        <div class="text-muted small">Tags: <%= project.tags %></div>
                    </div>
                </div>
            </a>
        </div>
        <% }) %>
    </div>
</div>
<% } %>