<% layout('layout/boilerplate') %>

    <div class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 4rem);">
        <div class="glass-card" style="width: 100%; max-width: 450px;">
            <div class="text-center mb-4">
                <i class="fas fa-user-plus fa-3x mb-3" style="color: var(--accent-primary);"></i>
                <h2 class="fw-bold">Create Account</h2>
                <p class="text-secondary">Join Aurora and start managing tasks</p>
            </div>

            <form action="/register" method="POST">
                <div class="mb-3">
                    <label class="form-label text-secondary fw-semibold">Full Name</label>
                    <input type="text" name="username" class="input-premium" placeholder="John Paul" required>
                </div>
                <div class="mb-3">
                    <label class="form-label text-secondary fw-semibold">Email Address</label>
                    <input type="email" name="email" class="input-premium" placeholder="name@company.com" required>
                </div>
                <div class="mb-4">
                    <label class="form-label text-secondary fw-semibold">Password</label>
                    <input type="password" name="password" class="input-premium" placeholder="Create a password"
                        required>
                </div>

                <button class="btn-premium w-100 mb-3" type="submit">Create Account</button>

                <div class="text-center">
                    <p class="text-secondary small">Already have an account?
                        <a href="/login" class="text-decoration-none fw-bold" style="color: var(--accent-primary);">Sign
                            In</a>
                    </p>
                </div>
            </form>
        </div>
    </div>