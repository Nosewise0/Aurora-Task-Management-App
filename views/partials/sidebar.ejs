<aside class="sidebar" id="sidebar">
    <div class="sidebar-toggle" id="sidebar-toggle">
        <i class="fas fa-chevron-left"></i>
    </div>
    <div class="sidebar-brand">
        <i class="fas fa-rocket"></i>
        <span>Aurora</span>
    </div>

    <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-link <%= path === '/dashboard' ? 'active' : '' %>">
            <i class="fas fa-th-large"></i>
            <span>Dashboard</span>
        </a>
        <a href="/tasks" class="nav-link <%= path.startsWith('/tasks') ? 'active' : '' %>">
            <i class="fas fa-tasks"></i>
            <span>My Tasks</span>
        </a>
        <a href="/projects" class="nav-link <%= path.startsWith('/projects') ? 'active' : '' %>">
            <i class="fas fa-layer-group"></i>
            <span>Projects</span>
        </a>
        <!-- <a href="/team" class="nav-link <%= path.startsWith('/team') ? 'active' : '' %>">
            <i class="fas fa-users"></i>
            <span>Team</span>
        </a> -->
        <a href="/calendar" class="nav-link <%= path.startsWith('/calendar') ? 'active' : '' %>">
            <i class="fas fa-calendar-alt"></i>
            <span>Calendar</span>
        </a>
        <a href="/notifications" class="nav-link <%= path.startsWith('/notifications') ? 'active' : '' %>">
            <i class="fas fa-bell"></i>
            <span>Notifications</span>
        </a>
    </nav>

    <div class="sidebar-nav" style="flex: 0;">
        <% if (user) { %>
            <!-- <a href="/settings" class="nav-link <%= path.startsWith('/settings') ? 'active' : '' %>">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </a> -->
            <a href="/logout" class="nav-link">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
            <% } else { %>
                <a href="/login" class="nav-link <%= path === '/login' ? 'active' : '' %>">
                    <i class="fas fa-sign-in-alt"></i>
                    <span>Login</span>
                </a>
                <a href="/register" class="nav-link <%= path === '/register' ? 'active' : '' %>">
                    <i class="fas fa-user-plus"></i>
                    <span>Register</span>
                </a>
                <% } %>
    </div>
</aside>