<aside class="sidebar" id="sidebar">
    <div class="sidebar-toggle" id="sidebar-toggle">
        <i class="fas fa-chevron-left"></i>
    </div>
    <div class="sidebar-brand">
        <i class="fas fa-rocket"></i>
        <span>Aurora</span>
    </div>

    <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-link <%= path === '/dashboard' ? 'active' : '' %>">
            <i class="fas fa-th-large"></i>
            <span>Dashboard</span>
        </a>
        <a href="/tasks" class="nav-link <%= path.startsWith('/tasks') ? 'active' : '' %>">
            <i class="fas fa-tasks"></i>
            <span>My Tasks</span>
        </a>
        <a href="/projects" class="nav-link <%= path.startsWith('/projects') ? 'active' : '' %>">
            <i class="fas fa-layer-group"></i>
            <span>Projects</span>
        </a>
        <a href="/team" class="nav-link <%= path.startsWith('/team') ? 'active' : '' %>">
            <i class="fas fa-users"></i>
            <span>Team</span>
        </a>
        <!-- <a href="/calendar" class="nav-link <%= path.startsWith('/calendar') ? 'active' : '' %>">
            <i class="fas fa-calendar-alt"></i>
            <span>Calendar</span>
        </a> -->
        <a href="/notifications" class="nav-link <%= path.startsWith('/notifications') ? 'active' : '' %>">
            <i class="fas fa-bell"></i>
            <span>Notifications</span>
            <% if (typeof unreadCount !=='undefined' && unreadCount> 0) { %>
                <span class="badge bg-danger rounded-pill ms-auto">
                    <%= unreadCount %>
                </span>
                <% } %>
        </a>
    </nav>

    <div class="sidebar-nav" style="flex: 0; padding-bottom: 2rem;">
        <% if (user) { %>
            <div
                class="sidebar-user mt-auto pt-3 border-top border-color d-flex align-items-center justify-content-between px-2">
                <a href="/settings/profile"
                    class="text-decoration-none d-flex align-items-center gap-3 sidebar-user-link p-2 rounded flex-grow-1 overflow-hidden"
                    title="Settings">
                    <% if (user.avatar_url) { %>
                        <img src="<%= user.avatar_url %>" alt="User"
                            class="avatar-circle avatar-small object-fit-cover flex-shrink-0">
                        <% } else { %>
                            <div
                                class="avatar-circle avatar-small bg-primary text-white d-flex align-items-center justify-content-center fw-bold small flex-shrink-0">
                                <%= (user.username || user.name || ''
                                    ).split(' ').map(n => n?.charAt(0) || '').join('').toUpperCase().slice(0, 2) || ' ?'
                                    %>
                            </div>
                            <% } %>
                                <div class="sidebar-user-info overflow-hidden">
                                    <div class="fw-semibold text-truncate text-body" style="font-size: 0.9rem;">
                                        <%= user.username %>
                                    </div>
                                    <div class="text-secondary small text-truncate" style="font-size: 0.75rem;">
                                        <%= user.email %>
                                    </div>
                                </div>
                </a>
                <a href="/logout"
                    class="text-secondary p-2 ms-1 rounded sidebar-user-link d-flex align-items-center justify-content-center"
                    title="Logout" style="width: 36px; height: 36px;">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
            <% } else { %>
                <a href="/login" class="nav-link <%= path === '/login' ? 'active' : '' %>">
                    <i class="fas fa-sign-in-alt"></i>
                    <span>Login</span>
                </a>
                <a href="/register" class="nav-link <%= path === '/register' ? 'active' : '' %>">
                    <i class="fas fa-user-plus"></i>
                    <span>Register</span>
                </a>
                <% } %>
    </div>
</aside>