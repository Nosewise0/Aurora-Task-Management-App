<div class="ai-chat-container">
    <button class="ai-chat-toggle" id="ai-chat-toggle" title="Chat with Aurora AI">
        <i class="fas fa-magic"></i>
    </button>

    <div class="ai-chat-window" id="ai-chat-window">
        <div class="ai-chat-header">
            <div class="ai-chat-header-info">
                <div class="ai-chat-avatar">
                    <i class="fas fa-robot"></i>
                </div>
                <div class="ai-chat-title-group">
                    <span class="ai-chat-title">Aurora AI</span>
                    <span class="ai-chat-status">Online and ready</span>
                </div>
            </div>
            <button class="ai-chat-close d-flex align-items-center gap-2" id="ai-chat-close" style="padding: 0.5rem;">
                <span class="d-inline d-md-none fw-bold" style="font-size: 0.85rem;">Close</span>
                <i class="fas fa-times fa-lg"></i>
            </button>
        </div>

        <div class="ai-chat-messages" id="ai-chat-messages">
            <div class="ai-message ai-message-received">
                <div class="ai-message-bubble">
                    Hello! I'm Aurora AI. How can I help you manage your tasks today?
                </div>
                <span class="ai-message-time">Just now</span>
            </div>
        </div>

        <div class="ai-chat-input-area">
            <div class="ai-chat-input-wrapper">
                <input type="text" id="ai-chat-input" placeholder="Type your message..." autocomplete="off">
                <button class="ai-chat-send" id="ai-chat-send">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>
</div>
