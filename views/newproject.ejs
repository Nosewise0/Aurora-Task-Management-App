<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <!-- Page Header -->
        <div class="mb-4">
            <h1 class="fw-bold mb-1">Create New Project</h1>
            <p class="text-secondary">Define a new project to track with your team. This is a visual-only stub, no data
                is saved yet.</p>
        </div>

        <div class="row">
            <!-- Form Section -->
            <div class="col-lg-8">
                <div class="glass-card p-4">
                    <form action="/projects/new" method="POST">
                        <!-- Project Title -->
                        <div class="mb-4">
                            <label for="projectTitle" class="form-label fw-semibold"
                                style="color: var(--text-main);">Project
                                Title</label>
                            <input type="text" name="title" class="form-control bg-main border-color p-3"
                                id="projectTitle" placeholder="e.g., Aurora Web Platform"
                                style="background: var(--bg-main) !important; color: var(--text-main);" required>
                        </div>

                        <!-- Project Description -->
                        <div class="mb-4">
                            <label for="projectDesc" class="form-label fw-semibold"
                                style="color: var(--text-main);">Project
                                Description</label>
                            <textarea name="description" class="form-control bg-main border-color p-3" id="projectDesc"
                                rows="4" placeholder="What is this project about?"
                                style="background: var(--bg-main) !important; color: var(--text-main);"
                                required></textarea>
                        </div>

                        <div class="row">
                            <!-- Project Owner -->
                            <div class="col-md-6 mb-4">
                                <label for="projectOwner" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Owner</label>
                                <input type="text" name="owner" class="form-control bg-main border-color p-3"
                                    id="projectOwner" placeholder="e.g., John Doe"
                                    style="background: var(--bg-main) !important; color: var(--text-main);" required>
                            </div>

                            <!-- Project Status -->
                            <div class="col-md-6 mb-4">
                                <label for="projectStatus" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Status</label>
                                <select name="status" class="form-select bg-main border-color p-3" id="projectStatus"
                                    style="background: var(--bg-main) !important; color: var(--text-main);" required>
                                    <option value="planning">Planning</option>
                                    <option value="active">Active</option>
                                    <option value="on-hold">On Hold</option>
                                    <option value="completed">Completed</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Start Date -->
                            <div class="col-md-6 mb-4">
                                <label for="projectStart" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Start Date</label>
                                <input type="date" name="start_date" class="form-control bg-main border-color p-3"
                                    id="projectStart"
                                    style="background: var(--bg-main) !important; color: var(--text-main);" required>
                            </div>

                            <!-- Target End Date -->
                            <div class="col-md-6 mb-4">
                                <label for="projectEnd" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Target End Date</label>
                                <input type="date" name="end_date" class="form-control bg-main border-color p-3"
                                    id="projectEnd"
                                    style="background: var(--bg-main) !important; color: var(--text-main);" required>
                            </div>
                        </div>

                        <!-- Due Days -->
                        <div class="mb-4">
                            <label for="projectDueDays" class="form-label fw-semibold"
                                style="color: var(--text-main);">Due Days</label>
                            <input type="number" name="due_days" class="form-control bg-main border-color p-3"
                                id="projectDueDays" placeholder="e.g., 30"
                                style="background: var(--bg-main) !important; color: var(--text-main);" required>
                        </div>

                        <!-- Project Tags -->
                        <div class="mb-4">
                            <label for="projectTags" class="form-label fw-semibold"
                                style="color: var(--text-main);">Tags / Labels</label>
                            <input type="text" name="tags" class="form-control bg-main border-color p-3"
                                id="projectTags" placeholder="e.g., Web, Q1 roadmap, Priority"
                                style="background: var(--bg-main) !important; color: var(--text-main);">
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-3 mt-2">
                            <button type="submit" class="btn-premium px-5 py-3">
                                <i class="fas fa-plus me-2"></i>Create Project
                            </button>
                            <a href="/projects"
                                class="btn btn-outline-secondary border-color px-4 py-3 d-flex align-items-center"
                                style="color: var(--text-secondary);">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tips Section -->
            <div class="col-lg-4">
                <div class="glass-card p-4">
                    <h6 class="fw-bold mb-3"><i class="fas fa-lightbulb me-2 text-warning"></i>Project Setup Ideas</h6>
                    <ul class="list-unstyled smaller text-secondary mb-0">
                        <li class="mb-3">
                            <i class="fas fa-check-circle me-2 text-primary"></i>
                            Use clear names like "Website Redesign Q2" instead of generic labels.
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle me-2 text-primary"></i>
                            Align status options with your board (Planning, Active, On Hold, Completed).
                        </li>
                        <li>
                            <i class="fas fa-check-circle me-2 text-primary"></i>
                            Later, you can connect this page to a database to actually save projects.
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>