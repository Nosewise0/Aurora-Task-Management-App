<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aurora - Premium Task Management</title>
    <link rel="icon" href="auroraLogo.png" type="image/x-icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/chatbox.css">
</head>

<body>
    <%- include('../partials/ai-chatbox') %>
    <div class="global-loader" id="global-loader">
        <div class="global-loader-inner">
            <div class="global-loader-logo">
                <i class="fas fa-rocket me-2"></i>
                <span>Aurora</span>
            </div>
            <div class="global-loader-spinner"></div>
            <p class="global-loader-text">Loading your workspace...</p>
        </div>
    </div>

    <div class="d-md-none d-flex justify-content-between align-items-center bg-white p-3 border-bottom position-fixed w-100 top-0" style="z-index: 1000;">
        <div class="d-flex align-items-center gap-2 fw-bold text-primary fs-5">
            <i class="fas fa-rocket"></i>
            <span>Aurora</span>
        </div>
        <button id="mobile-menu-btn" class="btn btn-sm btn-light border">
            <i class="fas fa-bars"></i>
        </button>
    </div>

    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <div class="app-container">
        <% if (user) { %>
            <%- include('../partials/sidebar') %>
                <% } %>

                    <main class="main-content <%= user ? '' : 'main-content-no-sidebar' %>" id="main-content">
                        <%- include('../partials/_messages') %>
                            <%- body %>
                    </main>
    </div>

    <script src="/aurora-ui.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>