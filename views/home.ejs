<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <% if (user)  {%>
                <h1 class="fw-bold mb-1">Dashboard</h1>
                <p class="text-secondary">Welcome back <%= user.name %>, here's what's happening today.</p>
                <% } %>
            </div>
            <div>
                <button class="btn-premium">
                    <i class="fas fa-plus me-2"></i>New Task
                </button>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="glass-card">
                    <div class="text-secondary small mb-1">Total Tasks</div>
                    <div class="h3 fw-bold mb-0">24</div>
                    <div class="text-success small mt-2">
                        <i class="fas fa-arrow-up me-1"></i>12% increase
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass-card">
                    <div class="text-secondary small mb-1">In Progress</div>
                    <div class="h3 fw-bold mb-0">8</div>
                    <div class="text-primary small mt-2">
                        <i class="fas fa-clock me-1"></i>4 Due today
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass-card">
                    <div class="text-secondary small mb-1">Completed</div>
                    <div class="h3 fw-bold mb-0">16</div>
                    <div class="text-success small mt-2">
                        <i class="fas fa-check-circle me-1"></i>Completed 67%
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass-card">
                    <div class="text-secondary small mb-1">Upcoming</div>
                    <div class="h3 fw-bold mb-0">12</div>
                    <div class="text-muted small mt-2">
                        Next 7 days
                    </div>
                </div>
            </div>
        </div>

        <!-- Content Area -->
        <div class="row g-4">
            <div class="col-md-8">
                <div class="glass-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Recent Activity</h5>
                        <a href="#" class="text-decoration-none small" style="color: var(--accent-primary);">View
                            All</a>
                    </div>
                    <div class="data-grid">
                        <div class="grid-row">
                            <div class="me-3 p-2 bg-primary bg-opacity-10 rounded text-primary">
                                <i class="fas fa-code"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">Update API Documentation</div>
                                <div class="text-muted small">Updated 2 hours ago</div>
                            </div>
                            <div class="badge bg-secondary bg-opacity-25 text-secondary">Documentation</div>
                        </div>
                        <div class="grid-row">
                            <div class="me-3 p-2 bg-success bg-opacity-10 rounded text-success">
                                <i class="fas fa-bug"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">Fix Sidebar Toggle Bug</div>
                                <div class="text-muted small">Updated 5 hours ago</div>
                            </div>
                            <div class="badge bg-secondary bg-opacity-25 text-secondary">Bug Fix</div>
                        </div>
                        <div class="grid-row">
                            <div class="me-3 p-2 bg-warning bg-opacity-10 rounded text-warning">
                                <i class="fas fa-pencil-alt"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">Redesign Landing Page</div>
                                <div class="text-muted small">Updated Yesterday</div>
                            </div>
                            <div class="badge bg-secondary bg-opacity-25 text-secondary">Design</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card h-100">
                    <h5 class="fw-bold mb-4">Team Availability</h5>
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-secondary p-3 me-3">JP</div>
                        <div>
                            <div class="fw-bold">John Paul</div>
                            <div class="text-success small">Available</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-secondary p-3 me-3">BS</div>
                        <div>
                            <div class="fw-bold">Burlasoy</div>
                            <div class="text-danger small">In Meeting</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-secondary p-3 me-3">MP</div>
                        <div>
                            <div class="fw-bold">Malunggay Pandesal</div>
                            <div class="text-warning small">Away</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>