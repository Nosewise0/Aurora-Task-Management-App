<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="mb-4">
            <h1 class="fw-bold mb-1">Create New Task</h1>
            <p class="text-secondary">Fill in the details below to add a new task to your board.</p>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="glass-card p-4">
                    <form action="/tasks" method="POST">
                        <div class="mb-4">
                            <label for="title" class="form-label fw-semibold" style="color: var(--text-main);">Task
                                Title</label>
                            <input type="text" class="form-control bg-main border-color p-3" id="title" name="title"
                                placeholder="e.g., Design System Update" required
                                style="background: var(--bg-main) !important; color: var(--text-main);">
                        </div>

                        <div class="mb-4">
                            <label for="description" class="form-label fw-semibold"
                                style="color: var(--text-main);">Description</label>
                            <textarea class="form-control bg-main border-color p-3" id="description" name="description"
                                rows="4" placeholder="Describe the task requirements..."
                                style="background: var(--bg-main) !important; color: var(--text-main);"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label for="status" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Status</label>
                                <select class="form-select bg-main border-color p-3" id="status" name="status"
                                    style="background: var(--bg-main) !important; color: var(--text-main);">
                                    <option value="pending">To Do</option>
                                    <option value="in-progress">In Progress</option>
                                    <option value="review">Review</option>
                                    <option value="completed">Done</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label for="priority" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Priority</label>
                                <select class="form-select bg-main border-color p-3" id="priority" name="priority"
                                    style="background: var(--bg-main) !important; color: var(--text-main);">
                                    <option value="Low">Low</option>
                                    <option value="Medium" selected>Medium</option>
                                    <option value="High">High</option>
                                    <option value="Urgent">Urgent</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label for="dueDate" class="form-label fw-semibold" style="color: var(--text-main);">Due
                                    Date</label>
                                <input type="date" class="form-control bg-main border-color p-3" id="dueDate"
                                    name="due_date"
                                    style="background: var(--bg-main) !important; color: var(--text-main);">
                            </div>

                            <div class="col-md-6 mb-4">
                                <label for="category" class="form-label fw-semibold"
                                    style="color: var(--text-main);">Category</label>
                                <input type="text" class="form-control bg-main border-color p-3" id="category"
                                    name="category" placeholder="e.g., Design, Dev, Marketing"
                                    style="background: var(--bg-main) !important; color: var(--text-main);">
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-2">
                            <button type="submit" class="btn-premium px-5 py-3">
                                <i class="fas fa-plus me-2"></i>Create Task
                            </button>
                            <a href="/tasks"
                                class="btn btn-outline-secondary border-color px-4 py-3 d-flex align-items-center"
                                style="color: var(--text-secondary);">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="glass-card p-4">
                    <h6 class="fw-bold mb-3"><i class="fas fa-lightbulb me-2 text-warning"></i>Pro Tips</h6>
                    <ul class="list-unstyled smaller text-secondary mb-0">
                        <li class="mb-3">
                            <i class="fas fa-check-circle me-2 text-primary"></i>
                            Keep titles concise and action-oriented.
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle me-2 text-primary"></i>
                            Use descriptions to define "Done" criteria.
                        </li>
                        <li>
                            <i class="fas fa-check-circle me-2 text-primary"></i>
                            Set realistic due dates to avoid burnout.
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>