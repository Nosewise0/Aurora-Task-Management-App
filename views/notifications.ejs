<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="mb-4">
            <h1 class="fw-bold mb-1">Notifications</h1>
            <p class="text-secondary">See recent activity and updates across your workspace.</p>
        </div>

        <div class="glass-card">
            <% if (notifications && notifications.length) { %>
                <div class="data-grid">
                    <% notifications.forEach(function (n) { %>
                        <div
                            class="grid-row d-flex justify-content-between align-items-start py-2 px-3 border-bottom border-secondary border-opacity-10">
                            <div>
                                <div class="fw-semibold d-flex align-items-center">
                                    <%= n.title %>
                                        <% if (!n.read) { %>
                                            <span class="badge bg-primary bg-opacity-10 text-primary ms-2">New</span>
                                            <% } %>
                                </div>
                                <div class="text-secondary small mt-1">
                                    <%= n.body %>
                                </div>
                                <% if (n.type==='invite' && !n.read) { %>
                                    <button class="btn btn-sm btn-success mt-2"onclick="acceptInvite('<%= n.token %>', <%= n.id %>)">
                                        Accept
                                    </button>
                                    <a href="/projects/accept-invite/<%= n.token %>">Accept</a>
                                    <% } %>
                            </div>
                            <div class="text-muted small text-end ms-3">
                                <%= new Date(n.createdAt).toLocaleString() %>

                            </div>
                        </div>
                        <% }) %>
                </div>
                <% } else { %>
                    <div class="text-center text-secondary small py-4">
                        No notifications yet. You will see updates here when there is activity.
                    </div>
                    <% } %>
        </div>
    </div>

    <script>
        async function acceptInvite(token, id) {
            try {

                const res = await fetch(`/notifications/accept/${token}`, {
                    method: 'GET'
                });

                const text = await res.text();
                alert(text);

                await fetch(`/notifications/read/${id}`, { method: 'POST' });

                window.location.href = '/team';
            } catch (err) {
                console.error(err);
                alert("Failed to accept invitation");
            }
        }
    </script>