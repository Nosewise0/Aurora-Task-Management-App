<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0 settings-page">
        <div class="mb-4 d-flex justify-content-between align-items-end flex-wrap gap-2">
            <div>
                <h1 class="fw-bold mb-1">Settings</h1>
                <p class="text-secondary mb-0">Manage your account, preferences, and billing.</p>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fs-6" role="alert">
                        <i class="fas fa-check-circle me-1"></i><%= success %>
                    </div>
                <% } %>
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill fs-6" role="alert">
                        <i class="fas fa-exclamation-circle me-1"></i><%= error %>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="bento-grid">
            <!-- PROFILE BOX (Spans 2 columns) -->
            <div class="bento-card bento-span-2 border-accent">
                <h5 class="fw-bold mb-4">Profile Information</h5>
                <div class="mb-4 pb-4 border-bottom border-color d-flex flex-column flex-sm-row align-items-start align-items-sm-center gap-4">
                    <div class="position-relative avatar-upload-wrapper">
                        <% if (user.avatar_url) { %>
                            <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-circle avatar-large object-fit-cover shadow-sm">
                        <% } else { %>
                            <div class="avatar-circle avatar-large bg-primary text-white shadow-sm d-flex align-items-center justify-content-center fw-bold fs-3">
                                <%= (user.username || user.name || '').split(' ').map(n => n?.charAt(0) || '').join('').toUpperCase().slice(0, 2) || '?' %>
                            </div>
                        <% } %>
                        <form action="/settings/avatar" method="POST" enctype="multipart/form-data" id="avatarForm">
                            <label for="avatarInput" class="avatar-edit-overlay cursor-pointer" title="Change Avatar">
                                <i class="fas fa-camera text-white"></i>
                            </label>
                            <input type="file" id="avatarInput" name="avatar" class="d-none" accept="image/*" onchange="document.getElementById('avatarForm').submit()">
                        </form>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Profile Photo</h6>
                        <p class="text-secondary small mb-0">Recommended 256x256px. Max 2MB.</p>
                    </div>
                </div>

                <form action="/settings/profile" method="POST" class="mt-auto">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold">Name</label>
                            <input type="text" name="username" class="input-premium" value="<%= user.username %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold">Email Address</label>
                            <input type="email" name="email" class="input-premium" value="<%= user.email %>">
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small fw-bold">Bio</label>
                            <textarea name="bio" class="input-premium" rows="2" placeholder="Tell us something about yourself..."><%= user.bio || "" %></textarea>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn-premium">Save Changes</button>
                    </div>
                </form>
            </div>

            <!-- ACCOUNT STATUS (Spans 1 column, small height) -->
            <div class="bento-card">
                <h5 class="fw-bold mb-3">Account Status</h5>
                <div class="d-flex justify-content-between align-items-center p-3 rounded bg-main border border-secondary border-opacity-10 mb-3">
                    <div>
                        <div class="fw-bold">Premium Plan</div>
                        <div class="text-muted small">Renews April 2026.</div>
                    </div>
                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Active</span>
                </div>
                
                <h6 class="fw-bold mb-2 mt-auto">Two-factor authentication</h6>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-secondary small mb-0">Extra security layer.</p>
                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-2 py-1">Off</span>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary w-100 rounded-3 border-color">
                    <i class="fas fa-shield-alt me-2"></i>Enable 2FA
                </button>
            </div>

            <!-- SECURITY BOX -->
            <div class="bento-card">
                <h5 class="fw-bold mb-3">Security & Password</h5>
                <p class="text-secondary small mb-4">Update your credentials regularly.</p>
                <form action="/settings/security" method="POST" class="mt-auto">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label text-secondary small fw-bold">Current Password</label>
                            <input type="password" name="currentPassword" class="input-premium" placeholder="••••••••">
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small fw-bold">New Password</label>
                            <input type="password" name="newPassword" class="input-premium" placeholder="Choose a strong password">
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small fw-bold">Confirm New Password</label>
                            <input type="password" name="confirmPassword" class="input-premium" placeholder="Repeat new password">
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn-premium w-100">Update Password</button>
                    </div>
                </form>
            </div>

            <!-- NOTIFICATIONS -->
            <div class="bento-card bento-span-row-2">
                <h5 class="fw-bold mb-3">Notification Preferences</h5>
                <p class="text-secondary small mb-4">Choose when Aurora should keep you in the loop.</p>
                
                <div class="settings-toggle-list mb-4">
                    <div class="settings-toggle-row">
                        <div>
                            <div class="fw-semibold">Email notifications</div>
                            <div class="text-muted small">Updates for activity on your workspaces.</div>
                        </div>
                        <div class="form-check form-switch"><input class="form-check-input" type="checkbox" checked></div>
                    </div>
                    <div class="settings-toggle-row">
                        <div>
                            <div class="fw-semibold">Task reminders</div>
                            <div class="text-muted small">Reminders before due dates.</div>
                        </div>
                        <div class="form-check form-switch"><input class="form-check-input" type="checkbox" checked></div>
                    </div>
                    <div class="settings-toggle-row">
                        <div>
                            <div class="fw-semibold">Team mentions</div>
                            <div class="text-muted small">Notified when teammates assign work.</div>
                        </div>
                        <div class="form-check form-switch"><input class="form-check-input" type="checkbox" checked></div>
                    </div>
                    <div class="settings-toggle-row">
                        <div>
                            <div class="fw-semibold">Weekly summary</div>
                            <div class="text-muted small">Receive a weekly digest of highlights.</div>
                        </div>
                        <div class="form-check form-switch"><input class="form-check-input" type="checkbox"></div>
                    </div>
                </div>
                <div class="mt-auto">
                    <button type="button" class="btn btn-outline-secondary w-100 rounded-3 border-color">Save Preferences</button>
                </div>
            </div>

            <!-- APPEARANCE -->
            <div class="bento-card">
                <h5 class="fw-bold mb-3">Appearance</h5>
                <p class="text-secondary small mb-3">Personalize your workspace.</p>
                
                <div class="settings-theme-grid mb-4">
                    <div class="settings-theme-option active">
                        <div class="settings-theme-swatch settings-theme-swatch-light"></div>
                        <div>
                            <div class="fw-semibold">Light</div>
                        </div>
                    </div>
                    <div class="settings-theme-option">
                        <div class="settings-theme-swatch settings-theme-swatch-dark"></div>
                        <div>
                            <div class="fw-semibold">Dark</div>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-secondary small fw-bold">Density</label>
                    <select class="input-premium">
                        <option>Comfortable</option>
                        <option>Compact</option>
                        <option>Cozy</option>
                    </select>
                </div>

                <div class="settings-preview-shell mt-auto">
                    <div class="settings-preview-sidebar"></div>
                    <div class="settings-preview-main">
                        <div class="settings-preview-row"></div>
                        <div class="settings-preview-row"></div>
                        <div class="settings-preview-row short"></div>
                    </div>
                </div>
            </div>

            <!-- BILLING -->
            <div class="bento-card bento-span-2">
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start mb-4 gap-3">
                    <div>
                        <h5 class="fw-bold mb-1">Billing & Invoices</h5>
                        <p class="text-secondary small mb-0">Manage your plan, payment methods, and invoices.</p>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="settings-plan-pill">
                            <i class="fas fa-rocket me-2"></i> Pro workspace
                        </div>
                        <div>
                            <div class="fw-bold">$16 <span class="small text-muted">/ month</span></div>
                        </div>
                    </div>
                </div>

                <div class="border-top pt-3 mb-4">
                    <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between settings-payment-row gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="settings-card-brand">
                                <i class="fab fa-cc-visa"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Visa ending in 4242</div>
                                <div class="text-muted small">Expires 09/28 · Billing email <%= user.email %></div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-3 border-color">Remove</button>
                            <button type="button" class="btn btn-sm btn-premium">Update</button>
                        </div>
                    </div>
                </div>

                <h6 class="fw-bold mb-2">Recent Invoices</h6>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <tbody class="small border-top-0">
                            <tr>
                                <td class="border-0 px-0">Feb 2, 2026</td>
                                <td class="border-0">Pro workspace · Monthly</td>
                                <td class="border-0 text-end">
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1">Paid · $16.00</span>
                                </td>
                            </tr>
                            <tr>
                                <td class="border-bottom-0 px-0">Jan 2, 2026</td>
                                <td class="border-bottom-0">Pro workspace · Monthly</td>
                                <td class="border-bottom-0 text-end">
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1">Paid · $16.00</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>