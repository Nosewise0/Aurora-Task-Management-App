<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0 settings-page">
        <div class="mb-4">
            <h1 class="fw-bold mb-1">Settings</h1>
            <p class="text-secondary">Manage your account settings and preferences.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-3">
                <div class="glass-card p-2 settings-sidebar">
                    <nav class="nav flex-column">
                        <a class="nav-link py-2 px-3 mb-1 rounded settings-nav-link <%= section === 'profile' ? 'settings-nav-link-active' : '' %>"
                            href="/settings/profile">
                            <i class="fas fa-user me-2"></i>Profile
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded settings-nav-link <%= section === 'notifications' ? 'settings-nav-link-active' : '' %>"
                            href="/settings/notifications">
                            <i class="fas fa-bell me-2"></i>Notifications
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded settings-nav-link <%= section === 'security' ? 'settings-nav-link-active' : '' %>"
                            href="/settings/security">
                            <i class="fas fa-shield-alt me-2"></i>Security
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded settings-nav-link <%= section === 'appearance' ? 'settings-nav-link-active' : '' %>"
                            href="/settings/appearance">
                            <i class="fas fa-palette me-2"></i>Appearance
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded settings-nav-link <%= section === 'billing' ? 'settings-nav-link-active' : '' %>"
                            href="/settings/billing">
                            <i class="fas fa-credit-card me-2"></i>Billing
                        </a>
                    </nav>
                </div>
            </div>

            <div class="col-md-9">
                <% if (section==='profile' ) { %>
                    <div class="glass-card mb-4">
                        <h5 class="fw-bold mb-4">Profile Information</h5>
                        
                        <div class="mb-4 pb-4 border-bottom border-color d-flex align-items-center gap-4">
                            <div class="position-relative avatar-upload-wrapper">
                                <% if (user.avatar_url) { %>
                                    <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-circle avatar-large object-fit-cover shadow-sm">
                                <% } else { %>
                                    <div class="avatar-circle avatar-large bg-primary text-white shadow-sm d-flex align-items-center justify-content-center fw-bold fs-3">
                                        <%= (user.username || user.name || '').split(' ').map(n => n?.charAt(0) || '').join('').toUpperCase().slice(0, 2) || '?' %>
                                    </div>
                                <% } %>
                                <form action="/settings/avatar" method="POST" enctype="multipart/form-data" id="avatarForm">
                                    <label for="avatarInput" class="avatar-edit-overlay cursor-pointer" title="Change Avatar">
                                        <i class="fas fa-camera text-white"></i>
                                    </label>
                                    <input type="file" id="avatarInput" name="avatar" class="d-none" accept="image/*" onchange="document.getElementById('avatarForm').submit()">
                                </form>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Profile Photo</h6>
                                <p class="text-secondary small mb-0">Recommended 256x256px. Max 2MB.</p>
                            </div>
                        </div>

                        <form action="/settings/profile" method="POST">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label text-secondary small fw-bold">Name</label>
                                    <input type="text" name="username" class="input-premium"
                                        value="<%= user.username %>">
                                </div>
                                <div class="col-12">
                                    <label class="form-label text-secondary small fw-bold">Email Address</label>
                                    <input type="email" name="email" class="input-premium" value="<%= user.email %>">
                                </div>
                                <div class="col-12">
                                    <label class="form-label text-secondary small fw-bold">Bio</label>
                                    <textarea name="bio" class="input-premium" rows="3"
                                        placeholder="Tell us something about yourself..."><%= user.bio || "" %></textarea>
                                </div>
                            </div>
                            <div class="mt-4 d-flex gap-2">
                                <button type="submit" class="btn-premium">Save Changes</button>
                                <button type="button" class="btn btn-outline-secondary rounded-3 border-color">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>

                    <div class="glass-card">
                        <h5 class="fw-bold mb-3">Account Status</h5>
                        <div
                            class="d-flex justify-content-between align-items-center p-3 rounded bg-main border border-secondary border-opacity-10">
                            <div>
                                <div class="fw-bold">Premium Subscription</div>
                                <div class="text-muted small">Your next billing date is April 2, 2026.</div>
                            </div>
                            <span
                                class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Active</span>
                        </div>
                    </div>
                    <% } else if (section==='notifications' ) { %>
                        <div class="glass-card mb-4">
                            <h5 class="fw-bold mb-3">Notification Preferences</h5>
                            <p class="text-secondary small mb-4">
                                Choose when Aurora should keep you in the loop.
                            </p>

                            <div class="settings-toggle-list">
                                <div class="settings-toggle-row">
                                    <div>
                                        <div class="fw-semibold">Email notifications</div>
                                        <div class="text-muted small">
                                            Receive email updates for activity on your workspaces.
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" checked>
                                    </div>
                                </div>

                                <div class="settings-toggle-row">
                                    <div>
                                        <div class="fw-semibold">Task reminders</div>
                                        <div class="text-muted small">
                                            Get reminders before due dates and upcoming tasks.
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" checked>
                                    </div>
                                </div>

                                <div class="settings-toggle-row">
                                    <div>
                                        <div class="fw-semibold">Team mentions</div>
                                        <div class="text-muted small">
                                            Be notified when teammates mention you or assign work.
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" checked>
                                    </div>
                                </div>

                                <div class="settings-toggle-row">
                                    <div>
                                        <div class="fw-semibold">Weekly summary</div>
                                        <div class="text-muted small">
                                            Receive a weekly digest of progress and highlights.
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox">
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4">
                                <button type="button" class="btn-premium">Save Notification Settings</button>
                            </div>
                        </div>
                        <% } else if (section==='security' ) { %>
                            <div class="glass-card mb-4">
                                <h5 class="fw-bold mb-3">Security</h5>
                                <p class="text-secondary small mb-4">
                                    Keep your account secure with strong credentials and 2FA.
                                </p>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label text-secondary small fw-bold">Current Password</label>
                                        <input type="password" class="input-premium" placeholder="••••••••">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-secondary small fw-bold">New Password</label>
                                        <input type="password" class="input-premium"
                                            placeholder="Choose a strong password">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-secondary small fw-bold">Confirm New
                                            Password</label>
                                        <input type="password" class="input-premium" placeholder="Repeat new password">
                                    </div>
                                </div>

                                <div class="mt-4 d-flex gap-2">
                                    <button type="button" class="btn-premium">Update Password</button>
                                    <button type="button" class="btn btn-outline-secondary rounded-3 border-color">
                                        Reset via email
                                    </button>
                                </div>
                            </div>

                            <div class="glass-card">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <h6 class="fw-bold mb-1">Two-factor authentication</h6>
                                        <p class="text-secondary small mb-0">
                                            Add an extra layer of security using an authenticator app.
                                        </p>
                                    </div>
                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-2">
                                        Not configured
                                    </span>
                                </div>
                                <button type="button" class="btn-premium">
                                    <i class="fas fa-shield-alt me-2"></i>Enable 2FA
                                </button>
                            </div>
                            <% } else if (section==='appearance' ) { %>
                                <div class="glass-card mb-4">
                                    <h5 class="fw-bold mb-3">Appearance</h5>
                                    <p class="text-secondary small mb-4">
                                        Personalize how Aurora looks and feels for you.
                                    </p>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label text-secondary small fw-bold">Theme</label>
                                            <div class="settings-theme-grid">
                                                <div class="settings-theme-option active">
                                                    <div class="settings-theme-swatch settings-theme-swatch-light">
                                                    </div>
                                                    <div>
                                                        <div class="fw-semibold">Light</div>
                                                        <div class="text-muted small">Bright, minimal workspace</div>
                                                    </div>
                                                </div>
                                                <div class="settings-theme-option">
                                                    <div class="settings-theme-swatch settings-theme-swatch-dark"></div>
                                                    <div>
                                                        <div class="fw-semibold">Dark</div>
                                                        <div class="text-muted small">Low-light, focused view</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-secondary small fw-bold">Density</label>
                                            <select class="input-premium">
                                                <option>Comfortable</option>
                                                <option>Compact</option>
                                                <option>Cozy</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="glass-card">
                                    <h6 class="fw-bold mb-2">Preview</h6>
                                    <p class="text-secondary small mb-3">
                                        See how your theme and density feel before applying.
                                    </p>
                                    <div class="settings-preview-shell">
                                        <div class="settings-preview-sidebar"></div>
                                        <div class="settings-preview-main">
                                            <div class="settings-preview-row"></div>
                                            <div class="settings-preview-row"></div>
                                            <div class="settings-preview-row short"></div>
                                        </div>
                                    </div>
                                </div>
                                <% } else if (section==='billing' ) { %>
                                    <div class="glass-card mb-4">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div>
                                                <h5 class="fw-bold mb-1">Billing</h5>
                                                <p class="text-secondary small mb-0">
                                                    Manage your plan, payment methods, and invoices.
                                                </p>
                                            </div>
                                            <span
                                                class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                                                Premium · Active
                                            </span>
                                        </div>

                                        <div class="row g-3 align-items-center mb-3">
                                            <div class="col-md-6">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="settings-plan-pill">
                                                        <i class="fas fa-rocket me-2"></i> Pro workspace
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold">$16 <span class="small text-muted">/
                                                                month</span></div>
                                                        <div class="text-muted small">Billed annually</div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-md-end">
                                                <button type="button"
                                                    class="btn btn-outline-secondary rounded-3 border-color me-2">
                                                    Change plan
                                                </button>
                                                <button type="button" class="btn-premium">
                                                    Update payment method
                                                </button>
                                            </div>
                                        </div>

                                        <div class="border-top pt-3 mt-3">
                                            <h6 class="fw-bold mb-2">Payment method</h6>
                                            <div
                                                class="d-flex align-items-center justify-content-between settings-payment-row">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="settings-card-brand">
                                                        <i class="fab fa-cc-visa"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-semibold">Visa ending in 4242</div>
                                                        <div class="text-muted small">Expires 09/28 · Billing email <%=
                                                                user.email %>
                                                        </div>
                                                    </div>
                                                </div>
                                                <button type="button"
                                                    class="btn btn-sm btn-outline-secondary rounded-3 border-color">
                                                    Remove
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="glass-card">
                                        <h6 class="fw-bold mb-3">Invoices</h6>
                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0">
                                                <thead>
                                                    <tr class="text-secondary small">
                                                        <th scope="col">Date</th>
                                                        <th scope="col">Description</th>
                                                        <th scope="col">Amount</th>
                                                        <th scope="col" class="text-end">Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody class="small">
                                                    <tr>
                                                        <td>Feb 2, 2026</td>
                                                        <td>Pro workspace · Monthly</td>
                                                        <td>$16.00</td>
                                                        <td class="text-end">
                                                            <span
                                                                class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1">Paid</span>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td>Jan 2, 2026</td>
                                                        <td>Pro workspace · Monthly</td>
                                                        <td>$16.00</td>
                                                        <td class="text-end">
                                                            <span
                                                                class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1">Paid</span>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td>Dec 2, 2025</td>
                                                        <td>Pro workspace · Monthly</td>
                                                        <td>$16.00</td>
                                                        <td class="text-end">
                                                            <span
                                                                class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1">Paid</span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <% } %>
            </div>
        </div>
    </div>