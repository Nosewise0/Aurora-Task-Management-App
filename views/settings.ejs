<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="mb-4">
            <h1 class="fw-bold mb-1">Settings</h1>
            <p class="text-secondary">Manage your account settings and preferences.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-3">
                <div class="glass-card p-2">
                    <nav class="nav flex-column">
                        <a class="nav-link active py-2 px-3 mb-1 rounded bg-primary bg-opacity-10 text-primary"
                            href="#">
                            <i class="fas fa-user me-2"></i>Profile
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded text-secondary" href="#">
                            <i class="fas fa-bell me-2"></i>Notifications
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded text-secondary" href="#">
                            <i class="fas fa-shield-alt me-2"></i>Security
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded text-secondary" href="#">
                            <i class="fas fa-palette me-2"></i>Appearance
                        </a>
                        <a class="nav-link py-2 px-3 mb-1 rounded text-secondary" href="#">
                            <i class="fas fa-credit-card me-2"></i>Billing
                        </a>
                    </nav>
                </div>
            </div>

            <div class="col-md-9">
                <div class="glass-card mb-4">
                    <h5 class="fw-bold mb-4">Profile Information</h5>
                    <form>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label text-secondary small fw-bold">First Name</label>
                                <input type="text" class="input-premium" value="<%= user.name  %>">
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary small fw-bold">Email Address</label>
                                <input type="email" class="input-premium" value="<%= user.email  %>">
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary small fw-bold">Bio</label>
                                <textarea class="input-premium" rows="3"
                                    placeholder="Tell us something about yourself..."></textarea>
                            </div>
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn-premium">Save Changes</button>
                        </div>
                    </form>
                </div>

                <div class="glass-card">
                    <h5 class="fw-bold mb-4">Account Status</h5>
                    <div
                        class="d-flex justify-content-between align-items-center p-3 rounded bg-main border border-secondary border-opacity-10">
                        <div>
                            <div class="fw-bold">Premium Subscription</div>
                            <div class="text-muted small">Your next billing date is April 2, 2026.</div>
                        </div>
                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Active</span>
                    </div>
                </div>
            </div>
        </div>
    </div>