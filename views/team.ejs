<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <h1 class="fw-bold mb-1">Team</h1>
                <p class="text-secondary">Manage your team members and their availability.</p>
            </div>
            <a href="/team/invite"
                class="btn-premium text-decoration-none d-flex align-items-center justify-content-center">
                <i class="fas fa-user-plus me-2"></i>Invite Member
            </a>
        </div>

        <% if (invites && invites.length) { %>
            <div class="row g-4">
                <% invites.forEach(invite=> { %>
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="glass-card p-4 h-100 d-flex flex-column position-relative transition-hover"
                            style="transition: transform 0.2sease, box-shadow 0.2s ease;">


                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <% if (invite.avatar_url) { %>
                                    <img src="<%= invite.avatar_url %>" alt="User"
                                        class="avatar-circle object-fit-cover shadow-sm"
                                        style="width: 56px; height: 56px;">
                                    <% } else { %>
                                        <div class="avatar-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm"
                                            style="width: 56px; height: 56px; font-size: 1.2rem;">
                                            <%= (invite.username || invite.email.split('@')[0]).slice(0,2).toUpperCase()
                                                %>
                                        </div>
                                        <% } %>

                                            <% if (invite.status==='pending' ) { %>
                                                <span
                                                    class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-1">Pending</span>
                                                <% } else if (invite.status==='accepted' ) { %>
                                                    <span
                                                        class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1">Accepted</span>
                                                    <% } else if (invite.status==='read' ) { %>
                                                        <span
                                                            class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-1">Read</span>
                                                        <% } %>
                            </div>


                            <h5 class="fw-bold mb-1 text-truncate"
                                title="<%= invite.username || invite.email.split('@')[0] %>">
                                <%= invite.username || invite.email.split('@')[0] %>
                            </h5>
                            <div class="text-secondary small mb-3 text-truncate" title="<%= invite.email %>">
                                <%= invite.email %>
                            </div>

                            <div class="mb-4">
                                <span
                                    class="badge bg-secondary bg-opacity-10 text-secondary px-2 py-1 border border-secondary border-opacity-10 rounded-pill">
                                    <i class="fas fa-tag me-1 smaller"></i>
                                    <%= invite.role %>
                                </span>
                            </div>

                            <div
                                class="mt-auto pt-3 border-top border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                                <div class="text-muted smaller" style="font-size: 0.75rem;">
                                    <i class="far fa-clock me-1"></i>
                                    <%= new Date(invite.invited_at).toLocaleDateString() %>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="/team/<%= invite.id %>"
                                        class="btn btn-sm btn-outline-secondary rounded-3 border-color"
                                        title="View Profile">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <% if (invite.status==='pending' ) { %>
                                        <form action="/team/<%= invite.id %>?_method=DELETE" method="POST"
                                            class="d-inline mb-0"
                                            onsubmit="return confirm('Are you sure you want to delete this invitation?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"
                                                title="Reject Invite">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                        <% } %>
                                </div>
                            </div>

                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } else { %>
                <div class="glass-card p-5 text-center">
                    <div class="text-muted mb-3 fs-1 opacity-25">
                        <i class="fas fa-users-slash"></i>
                    </div>
                    <h5 class="fw-bold">No team members yet</h5>
                    <p class="text-secondary small mb-0">Invite colleagues to start collaborating.</p>
                </div>
                <% } %>
    </div>