<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold mb-1">Team</h1>
                <p class="text-secondary">Manage your team members and their availability.</p>
            </div>
            <a href="/team/invite"
                class="btn-premium text-decoration-none d-flex align-items-center justify-content-center">
                <i class="fas fa-user-plus me-2"></i>Invite Member
            </a>
        </div>

        <div class="glass-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0"
                    style="--bs-table-bg: transparent; --bs-table-hover-bg: var(--bg-card-hover);">
                    <thead>
                        <tr class="border-secondary border-opacity-10">
                            <th class="px-4 py-3 text-secondary small text-uppercase">Member</th>
                            <th class="py-3 text-secondary small text-uppercase">Role</th>
                            <th class="py-3 text-secondary small text-uppercase">Status</th>
                            <th class="py-3 text-secondary small text-uppercase">Email</th>
                            <th class="py-3 text-secondary small text-uppercase">Activity</th>
                            <th class="px-4 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        <% if (invites && invites.length) { %>
                            <% invites.forEach(invite=> { %>
                                <tr class="align-middle">
                                    <td class="px-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-primary p-2 me-3"
                                                style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                <%= invite.email.split('@')[0].slice(0,2).toUpperCase() %>
                                            </div>
                                            <div class="fw-bold">
                                                <%= invite.email.split('@')[0] %>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <%= invite.role %>
                                    </td>
                                    <td>
                                        <% if (invite.status==='pending' ) { %>
                                            <span
                                                class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Pending</span>
                                            <% } else if (invite.status==='accepted' ) { %>
                                                <span
                                                    class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Accepted</span>
                                                <% } else if (invite.status==='read' ) { %>
                                                    <span
                                                        class="badge bg-info bg-opacity-10 text-info rounded-pill px-3">Read</span>
                                                    <% } %>
                                    </td>
                                    <td class="text-secondary">
                                        <%= invite.email %>
                                    </td>
                                    <td>
                                        <div class="text-secondary small">
                                            Invited at <%= new Date(invite.invited_at).toLocaleString() %>
                                        </div>
                                    </td>
                                    <td class="px-4 text-end">
                                        <% if (invite.status==='pending' ) { %>
                                            <a href="/notifications/accept/<%= invite.token %>"
                                                class="btn btn-sm btn-success me-2">Accept</a>
                                            <button class="btn btn-sm btn-danger"onclick="deleteInvite(<%= invite.id %>)">Reject</button>
                                            <% } %>
                                                <i class="fas fa-ellipsis-h text-muted cursor-pointer ms-2"></i>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center text-secondary py-4">No team members yet.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        async function deleteInvite(id) {
            if (!confirm("Are you sure you want to delete this invitation?")) return;
            try {
                const res = await fetch(`/team/${id}`, { method: "DELETE" });
                const data = await res.json();
                if (data.success) location.reload();
                else alert("Failed to delete invite");
            } catch (err) {
                console.error(err);
                alert("Error deleting invite");
            }
        }
    </script>