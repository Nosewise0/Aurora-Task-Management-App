<% layout('layout/boilerplate') %>

<div class="container project-details-container">

    <div class="mb-3">
        <a href="/projects" class="btn btn-outline-secondary d-flex align-items-center">
            <i class="fas fa-arrow-left me-2"></i> Back
        </a>
    </div>

    <div class="glass-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
            <div>
                <h1 class="fw-bold mb-1"><%= project.title %></h1>
                <p class="text-secondary mb-0"><%= project.description %></p>
            </div>
            <div class="d-flex gap-2 mt-2 mt-md-0">
                <a href="/projects/<%= project.id %>/edit" class="btn btn-outline-primary px-4 py-2 d-flex align-items-center">
                    <i class="fas fa-edit me-2"></i>Edit
                </a>
                <a href="/projects/<%= project.id %>/delete" class="btn btn-outline-danger px-4 py-2 d-flex align-items-center">
                    <i class="fas fa-trash-alt me-2"></i>Delete
                </a>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-3 mb-4">
            <div class="badge 
                <% if(project.status === 'active') { %> bg-success bg-opacity-10 text-success <% } %>
                <% if(project.status === 'planning') { %> bg-secondary bg-opacity-10 text-secondary <% } %>
                <% if(project.status === 'on-hold') { %> bg-warning bg-opacity-10 text-warning <% } %>
                rounded-pill px-3 py-2">
                <%= project.status.charAt(0).toUpperCase() + project.status.slice(1) %>
            </div>
            <div class="text-muted"><i class="fas fa-user me-1"></i> Owner: <%= project.owner %></div>
            <div class="text-muted"><i class="fas fa-calendar-alt me-1"></i> Start: <%= project.start_date %></div>
            <div class="text-muted"><i class="fas fa-calendar-check me-1"></i> End: <%= project.end_date %></div>
        </div>

        <% 
        let progress = 0; 
        if(project.start_date && project.end_date) { 
            const now = new Date(); 
            const start = new Date(project.start_date); 
            const end = new Date(project.end_date); 
            progress = Math.min(Math.round(((now - start) / (end - start)) * 100), 100); 
            progress = progress < 0 ? 0 : progress; 
        } 
        %>
        <div class="mb-4">
            <div class="d-flex justify-content-between small mb-1">
                <span class="text-secondary">Progress</span>
                <span class="text-primary fw-bold"><%= progress %>%</span>
            </div>
            <div class="progress">
                <div class="progress-bar" style="--progress: <%= progress || 0 %>%;"></div>
            </div>
        </div>

        <div class="mb-4">
            <% if(project.tags) { %>
                <% project.tags.split(',').forEach(tag => { %>
                    <span class="landing-pill me-2 mb-2"><%= tag.trim() %></span>
                <% }) %>
            <% } %>
        </div>

        <div class="glass-card p-3 mb-0">
            <h6 class="fw-bold mb-2"><i class="fas fa-sticky-note me-2 text-warning"></i>Project Notes</h6>
            <p class="text-secondary mb-0">Detailed notes about the project can go here.</p>
        </div>
    </div>
</div>