<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="mb-4">
            <h1 class="fw-bold mb-1">
                <%= project.title %>
            </h1>
            <p class="text-secondary">
                <%= project.description %>
            </p>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="glass-card p-4 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Project Overview</h5>
                        <div class="d-flex gap-2">
                            <a href="/projects/<%= project.id %>/edit"
                                class="btn btn-outline-primary border-color px-4 py-2 d-flex align-items-center"
                                style="color: var(--text-main);">
                                <i class="fas fa-edit me-2"></i>Edit
                            </a>
                            <a href="/projects/<%= project.id %>/delete"
                                class="btn btn-outline-danger px-4 py-2 d-flex align-items-center">
                                <i class="fas fa-trash-alt me-2"></i>Delete
                            </a>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <span class="badge rounded-pill px-3 py-2
                            <% if(project.status === 'active')   { %> bg-success bg-opacity-10 text-success  <% } %>
                            <% if(project.status === 'planning') { %> bg-secondary bg-opacity-10 text-secondary <% } %>
                            <% if(project.status === 'on-hold')  { %> bg-warning bg-opacity-10 text-warning  <% } %>">
                            <%= project.status.charAt(0).toUpperCase() + project.status.slice(1) %>
                        </span>
                        <span class="text-secondary"><i class="fas fa-calendar-alt me-1"></i>Start: <%=
                                project.start_date %></span>
                        <span class="text-secondary"><i class="fas fa-calendar-check me-1"></i>End: <%= project.end_date
                                %></span>
                        <% if(project.due_days) { %>
                            <span class="text-secondary"><i class="fas fa-clock me-1"></i>
                                <%= project.due_days %> days
                            </span>
                            <% } %>
                    </div>

                    <% let progress=0; if(project.start_date && project.end_date) { const now=new Date(); const
                        start=new Date(project.start_date); const end=new Date(project.end_date);
                        progress=Math.min(Math.round(((now - start) / (end - start)) * 100), 100); if(progress < 0)
                        progress=0; } %>
                        <div class="mb-4">
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-secondary">Progress</span>
                                <span class="fw-bold" style="color: var(--accent)">
                                    <%= progress %>%
                                </span>
                            </div>
                            <div class="progress">
                                <div class="progress-bar" style="--progress: <%= progress %>%;"></div>
                            </div>
                        </div>

                        <% if(project.tags) { %>
                            <div>
                                <% project.tags.split(',').forEach(tag=> { %>
                                    <span class="landing-pill me-2 mb-2">
                                        <%= tag.trim() %>
                                    </span>
                                    <% }) %>
                            </div>
                            <% } %>
                </div>

                <div class="glass-card p-4">
                    <h6 class="fw-bold mb-2"><i class="fas fa-sticky-note me-2 text-warning"></i>Project Notes</h6>
                    <p class="text-secondary mb-0">Detailed notes and activity for this project will appear here.</p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="glass-card p-4">
                    <h6 class="fw-bold mb-3"><i class="fas fa-info-circle me-2 text-primary"></i>Project Details</h6>
                    <ul class="list-unstyled smaller mb-0">
                        <li class="mb-3 d-flex justify-content-between">
                            <span class="text-secondary">Status</span>
                            <span class="fw-semibold" style="color: var(--text-main);">
                                <%= project.status.charAt(0).toUpperCase() + project.status.slice(1) %>
                            </span>
                        </li>
                        <li class="mb-3 d-flex justify-content-between">
                            <span class="text-secondary">Start Date</span>
                            <span class="fw-semibold" style="color: var(--text-main);">
                                <%= project.start_date || '—' %>
                            </span>
                        </li>
                        <li class="mb-3 d-flex justify-content-between">
                            <span class="text-secondary">End Date</span>
                            <span class="fw-semibold" style="color: var(--text-main);">
                                <%= project.end_date || '—' %>
                            </span>
                        </li>
                        <li class="d-flex justify-content-between">
                            <span class="text-secondary">Due Days</span>
                            <span class="fw-semibold" style="color: var(--text-main);">
                                <%= project.due_days || '—' %>
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>