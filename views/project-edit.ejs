<% layout('layout/boilerplate') %>

    <div class="container project-details-container">


        <div class="mb-3">
            <a href="/projects" class="btn btn-outline-secondary d-flex align-items-center">
                <i class="fas fa-arrow-left me-2"></i> Back
            </a>
        </div>


        <div class="glass-card mb-4">
            <h2 class="fw-bold mb-4"><i class="fas fa-edit me-2 text-primary"></i>Edit Project</h2>

            <form action="/projects/<%= project.id %>/edit" method="POST">


                <div class="mb-3">
                    <label for="title" class="form-label fw-semibold">Project Title</label>
                    <input type="text" name="title" id="title" class="form-control input-premium"
                        value="<%= project.title %>" required>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label fw-semibold">Description</label>
                    <textarea name="description" id="description" rows="4" class="form-control input-premium"
                        required><%= project.description %></textarea>
                </div>

                <div class="mb-3">
                    <label for="status" class="form-label fw-semibold">Status</label>
                    <select name="status" id="status" class="form-select input-premium">
                        <option value="active" <%=project.status==='active' ? 'selected' : '' %>>Active</option>
                        <option value="planning" <%=project.status==='planning' ? 'selected' : '' %>>Planning</option>
                        <option value="on-hold" <%=project.status==='on-hold' ? 'selected' : '' %>>On-Hold</option>
                    </select>
                </div>

                <div class="mb-3 row">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label for="start_date" class="form-label fw-semibold">Start Date</label>
                        <input type="date" name="start_date" id="start_date" class="form-control input-premium"
                            value="<%= project.start_date %>" required>
                    </div>
                    <div class="col-md-6">
                        <label for="end_date" class="form-label fw-semibold">End Date</label>
                        <input type="date" name="end_date" id="end_date" class="form-control input-premium"
                            value="<%= project.end_date %>" required>
                    </div>
                </div>


                <div class="mb-3">
                    <label for="tags" class="form-label fw-semibold">Tags (comma-separated)</label>
                    <input type="text" name="tags" id="tags" class="form-control input-premium"
                        value="<%= project.tags %>">
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary px-4 py-2 d-flex align-items-center">
                        <i class="fas fa-save me-2"></i> Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>