<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold mb-1">Edit Task</h1>
                <p class="text-secondary">Update the details of this task.</p>
            </div>

            <a href="/tasks/<%= task.id %>" class="btn btn-outline-secondary border-0">
                <i class="fas fa-arrow-left me-2"></i>Back
            </a>
        </div>

        <div class="glass-card">
            <form action="/tasks/<%= task.id %>?_method=PUT" method="POST">
                <div class="row g-4">
                    <div class="col-12">
                        <label class="form-label fw-semibold mb-1">Title</label>
                        <input type="text" name="title" value="<%= task.title %>" class="input-premium" required>
                    </div>


                    <div class="col-12">
                        <label class="form-label fw-semibold mb-1">Description</label>
                        <textarea name="description" rows="4" class="input-premium"><%= task.description %></textarea>
                    </div>


                    <div class="col-md-6">
                        <label class="form-label fw-semibold mb-1">Status</label>
                        <select name="status" class="input-premium">
                            <option value="pending" <%=task.status==="pending" ? "selected" : "" %>>
                                Pending
                            </option>
                            <option value="in-progress" <%=task.status==="in-progress" ? "selected" : "" %>>
                                In Progress
                            </option>
                            <option value="review" <%=task.status==="review" ? "selected" : "" %>>
                                Review
                            </option>
                            <option value="completed" <%=task.status==="completed" ? "selected" : "" %>>
                                Completed
                            </option>
                        </select>
                    </div>


                    <div class="col-md-6">
                        <label class="form-label fw-semibold mb-1">Priority</label>
                        <select name="priority" class="input-premium">
                            <option value="low" <%=task.priority==="low" ? "selected" : "" %>>
                                Low
                            </option>
                            <option value="medium" <%=task.priority==="medium" ? "selected" : "" %>>
                                Medium
                            </option>
                            <option value="high" <%=task.priority==="high" ? "selected" : "" %>>
                                High
                            </option>
                            <option value="urgent" <%=task.priority==="urgent" ? "selected" : "" %>>
                                Urgent
                            </option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold mb-1">Category</label>
                        <input type="text" name="category" value="<%= task.category || '' %>" class="input-premium">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold mb-1">Due Date</label>
                        <input type="date" name="due_date"
                            value="<%= task.due_date ? task.due_date.toISOString().split('T')[0] : '' %>"
                            class="input-premium">
                    </div>
                </div>


                <div class="d-flex gap-2 mt-4">
                    <button class="btn-premium">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                    <a href="/tasks/<%= task.id %>" class="btn btn-outline-secondary border-0">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>