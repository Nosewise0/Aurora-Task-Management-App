<% layout('layout/boilerplate') %>

    <div class="container-fluid p-0">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="/tasks" class="btn-premium mb-3">
                    <i class="fas fa-arrow-left"></i> Back
                </a>

                <h1 class="fw-bold mb-1">
                    <%= task.title %>
                </h1>
                <p class="text-secondary">Task details and information</p>
            </div>

            <div class="d-flex gap-2">
                <a href="/tasks/<%= task.id %>/edit" class="btn-premium">
                    <i class="fas fa-pen"></i> Edit
                </a>

                <form action="/tasks/<%= task.id %>?_method=DELETE" method="POST">
                    <button class="btn-premium" style="background:linear-gradient(135deg,#ef4444,#dc2626)">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </form>
            </div>
        </div>


        <div class="glass-card">

            <div class="d-flex flex-wrap gap-2 mb-3">

                <span class="landing-status
            <%= task.status === 'completed'
                ? 'status-done'
                : task.status === 'in-progress'
                ? 'status-working'
                : 'status-stuck' %>">

                    <%= task.status %>
                </span>

                <span class="landing-pill-priority
            <%= task.priority === 'high'
                ? 'priority-high'
                : task.priority === 'medium'
                ? 'priority-medium'
                : 'priority-low' %>">

                    <%= task.priority %> priority
                </span>

            </div>


            <div class="mb-4">
                <h6 class="text-muted mb-2">Description</h6>
                <p class="text-secondary">
                    <%= task.description || "No description provided." %>
                </p>
            </div>


            <div class="row g-3">
                <div class="col-md-4">
                    <div class="grid-row">
                        <div>
                            <div class="text-muted small">Category</div>
                            <strong>
                                <%= task.category || "General" %>
                            </strong>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="grid-row">
                        <div>
                            <div class="text-muted small">Due Date</div>
                            <strong>
                                <%= formatDate(task.due_date) %>
                            </strong>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="grid-row">
                        <div>
                            <div class="text-muted small">Created</div>
                            <strong>
                                <%= formatDate(task.created_at) %>
                            </strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="glass-card mt-4">
            <h5 class="fw-bold mb-3">Activity</h5>
            <div class="data-grid">
                <div class="grid-row">
                    <span class="text-secondary">
                        Task created on <%= formatDate(task.created_at) %>
                    </span>
                </div>

                <% if(task.updated_at){ %>
                    <div class="grid-row">
                        <span class="text-secondary">
                            Last updated on <%= formatDate(task.updated_at) %>
                        </span>
                    </div>
                    <% } %>

            </div>

        </div>

    </div>